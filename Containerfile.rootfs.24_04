FROM ubuntu:noble

LABEL org.opencontainers.image.authors="Badr @pythops"

# Jammy sources
RUN echo "" >> /etc/apt/sources.list.d/ubuntu.sources && \
    echo "Types: deb" >>/etc/apt/sources.list.d/ubuntu.sources && \
    echo "URIs: http://ports.ubuntu.com/ubuntu-ports/" >> /etc/apt/sources.list.d/ubuntu.sources && \
    echo "Suites: jammy" >> /etc/apt/sources.list.d/ubuntu.sources && \
    echo "Components: main universe restricted multiverse" >> /etc/apt/sources.list.d/ubuntu.sources && \
    echo "Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg" >>/etc/apt/sources.list.d/ubuntu.sources

# Prevent interactive prompts during apt installs
ENV DEBIAN_FRONTEND=noninteractive
RUN ln -fs /usr/share/zoneinfo/Asia/Seoul /etc/localtime && \
    apt update && apt install -y tzdata && \
    dpkg-reconfigure --frontend noninteractive tzdata

# Nvidia required packages
RUN apt update && apt install -y \
        libgles2 \
        libpangoft2-1.0-0 \
        libxkbcommon0 \
        libwayland-egl1 \
        libwayland-cursor0 \
        libunwind8 \
        libasound2t64 \
        libpixman-1-0 \
        libjpeg-turbo8 \
        libinput10 \
        libcairo2 \
        libncursesw6 \
        libdrm-common \
        libdrm2 \
        libegl-mesa0 \
        libegl1 \
        libegl1-mesa \
        libgtk-3-0 \
        libgstreamer1.0-0 \
        libgstreamer-plugins-bad1.0-0 \
        libffi7 \
        libvulkan1 \
        libpcre3 \
        libssl-dev \
        device-tree-compiler \
        bridge-utils \
        i2c-tools \
        iso-codes \
        wget \
        cpio \
        busybox \
        nvme-cli \
        libseat1 \
        efibootmgr

# Additional tools
RUN apt install -y \
        systemd \
        bash-completion \
        build-essential \
        pkg-config \
        btrfs-progs \
        cmake \
        curl \
        dnsutils \
        htop \
        iotop \
        isc-dhcp-client \
        iputils-ping \
        kmod \
        linux-firmware \
        locales \
        net-tools \
        netplan.io \
        pciutils \
        python3-dev \
        ssh \
        sudo \
        udev \
        unzip \
        usbutils \
        neovim \
        wpasupplicant \
        parted \
        gdisk \
        fdisk \
        e2fsprogs \
        mtd-utils \
        python-is-python3 \
        git \
        gpgv1 \
        fwupd \
        network-manager


RUN wget -q https://github.com/pythops/tegratop/releases/latest/download/tegratop-linux-arm64 -O /usr/local/bin/tegratop && \
    chmod +x /usr/local/bin/tegratop

# ROS2 Kilted
RUN apt install -y software-properties-common && \
    add-apt-repository universe && \
    apt update && \
    apt install -y curl && \
    export ROS_APT_SOURCE_VERSION=$(curl -s https://api.github.com/repos/ros-infrastructure/ros-apt-source/releases/latest | grep -F "tag_name" | awk -F'"' '{print $4}') && \
    curl -L -o /tmp/ros2-apt-source.deb "https://github.com/ros-infrastructure/ros-apt-source/releases/download/${ROS_APT_SOURCE_VERSION}/ros2-apt-source_${ROS_APT_SOURCE_VERSION}.noble_all.deb" && \
    dpkg -i /tmp/ros2-apt-source.deb && \
    rm /tmp/ros2-apt-source.deb && \
    apt update && \
    apt install -y \
        ros-kilted-ros-base \
        ros-dev-tools \
        python3-argcomplete \
        python3-colcon-common-extensions \
        python3-rosdep && \
    rosdep init

# Source ROS2 in default shell for all users
RUN echo "source /opt/ros/kilted/setup.bash" >> /etc/skel/.bashrc && \
    echo "source /opt/ros/kilted/setup.zsh" >> /etc/skel/.zshrc

# Desktop environment (lightweight, needed for NoMachine/XRDP)
RUN apt install -y xfce4 xfce4-goodies dbus-x11

# Terminator terminal emulator + set as default for XFCE/Thunar
RUN apt install -y terminator && \
    mkdir -p /etc/skel/.config/xfce4 && \
    echo "TerminalEmulator=terminator" > /etc/skel/.config/xfce4/helpers.rc && \
    update-alternatives --set x-terminal-emulator /usr/bin/terminator

# ibus-hangul (Korean input) + remap Alt_R to Hangul key
RUN apt install -y ibus ibus-hangul && \
    sed -i 's/^	<RALT> = 108;/	\/\/<RALT> = 108;/' /usr/share/X11/xkb/keycodes/evdev && \
    sed -i 's/^	<HNGL> = 130;/	<HNGL> = 108;/' /usr/share/X11/xkb/keycodes/evdev

# NoMachine remote desktop
RUN wget -q https://web9001.nomachine.com/download/9.4/Arm/nomachine_9.4.14_1_arm64.deb -O /tmp/nomachine.deb && \
    dpkg -i /tmp/nomachine.deb && \
    rm /tmp/nomachine.deb && \
    systemctl enable nxserver

# Antigravity (Google's VS Code with Gemini)
RUN mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://us-central1-apt.pkg.dev/doc/repo-signing-key.gpg | \
    gpg --dearmor --yes -o /etc/apt/keyrings/antigravity-repo-key.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/antigravity-repo-key.gpg] https://us-central1-apt.pkg.dev/projects/antigravity-auto-updater-dev/ antigravity-debian main" > /etc/apt/sources.list.d/antigravity.list && \
    apt update && \
    apt install -y antigravity

# Claude Code
RUN curl -fsSL https://claude.ai/install.sh | bash

# XRDP remote desktop (port 3389)
RUN apt install -y xrdp xorgxrdp && \
    systemctl enable xrdp

# Dummy display (for headless remote desktop)
RUN apt install -y xserver-xorg-video-dummy
COPY config/xorg-dummy.conf /etc/X11/xorg.conf.d/10-dummy.conf

# Zsh + Oh My Zsh
RUN apt install -y zsh

# Resize the rootfs
COPY scripts/resizerootfs.sh /usr/local/bin
COPY scripts/resizerootfs.service /lib/systemd/system

# Generate locales
RUN locale-gen en_US.UTF-8

# Network configuration
COPY config/netcfg.yaml /etc/netplan/netcfg.yaml

# udev rules for F1TENTH sensors (Hokuyo LiDAR, VESC, Joypad)
COPY config/99-hokuyo.rules /etc/udev/rules.d/99-hokuyo.rules
COPY config/99-vesc.rules /etc/udev/rules.d/99-vesc.rules
COPY config/99-joypad-f710.rules /etc/udev/rules.d/99-joypad-f710.rules

# Enable services at startuo
RUN systemctl enable resizerootfs.service && \
    systemctl enable systemd-timesyncd

# New user
# username: MIRU
# password: 2
RUN useradd \
        --create-home \
        -G sudo,video,audio,dialout \
        -p $(openssl passwd -6 2) \
        -s /usr/bin/zsh \
        MIRU

# F1TENTH driver stack workspace
RUN su - MIRU -c '\
    source /opt/ros/kilted/setup.bash && \
    mkdir -p ~/f1tenth_ws/src && \
    cd ~/f1tenth_ws && \
    colcon build && \
    cd src && \
    git clone https://github.com/f1tenth/f1tenth_system.git && \
    cd f1tenth_system && \
    git submodule update --init --force --remote && \
    cd ~/f1tenth_ws && \
    rosdep update && \
    rosdep install --from-paths src -i -y && \
    colcon build'

# Add /usr/local/cuda/bin to the PATH
RUN echo "if [ -d \"/usr/local/cuda/bin\" ] ; then" >> /home/MIRU/.profile  && \
    echo "  PATH=\"/usr/local/cuda/bin:\$PATH\"" >> /home/MIRU/.profile  && \
    echo "fi" >> /home/MIRU/.profile

# Source ROS2 Kilted and F1TENTH workspace for MIRU user
RUN echo "source /opt/ros/kilted/setup.bash" >> /home/MIRU/.bashrc && \
    echo "source ~/f1tenth_ws/install/setup.bash 2>/dev/null" >> /home/MIRU/.bashrc

# Install Oh My Zsh + plugins for MIRU user
RUN su - MIRU -c 'sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended' && \
    git clone https://github.com/zsh-users/zsh-syntax-highlighting.git /home/MIRU/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting && \
    git clone https://github.com/zsh-users/zsh-autosuggestions.git /home/MIRU/.oh-my-zsh/custom/plugins/zsh-autosuggestions && \
    sed -i 's/plugins=(git)/plugins=(git zsh-syntax-highlighting zsh-autosuggestions)/' /home/MIRU/.zshrc && \
    echo "source /opt/ros/kilted/setup.zsh" >> /home/MIRU/.zshrc && \
    echo "source ~/f1tenth_ws/install/setup.zsh 2>/dev/null" >> /home/MIRU/.zshrc && \
    chown -R MIRU:MIRU /home/MIRU/.oh-my-zsh /home/MIRU/.zshrc

# Set Terminator as default terminal for MIRU in XFCE
RUN mkdir -p /home/MIRU/.config/xfce4 && \
    echo "TerminalEmulator=terminator" > /home/MIRU/.config/xfce4/helpers.rc && \
    chown -R MIRU:MIRU /home/MIRU/.config

# Set XFCE as default desktop session for NoMachine
RUN echo "[Desktop]" > /home/MIRU/.dmrc && \
    echo "Session=xfce" >> /home/MIRU/.dmrc && \
    chown MIRU:MIRU /home/MIRU/.dmrc
