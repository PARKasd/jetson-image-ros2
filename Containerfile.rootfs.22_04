FROM ubuntu:jammy

LABEL org.opencontainers.image.authors="Badr @pythops"

# Use KAIST mirror for faster apt downloads in Korea
RUN sed -i 's|http://ports.ubuntu.com/ubuntu-ports|http://ftp.kaist.ac.kr/ubuntu-ports|g' /etc/apt/sources.list && \
    echo "deb http://ftp.kaist.ac.kr/ubuntu-ports/ focal main" >> /etc/apt/sources.list && \
    apt update

RUN rm /var/lib/dpkg/info/libc-bin.* && \
    apt-get clean && \
    apt-get update && \
    apt-get install -y --reinstall libc-bin

# Disable dpkg path filters from minimal Ubuntu image (they may exclude /opt files)
RUN rm -f /etc/dpkg/dpkg.cfg.d/excludes /etc/dpkg/dpkg.cfg.d/docker-apt-speedup

# Prevent interactive prompts during apt installs
ENV DEBIAN_FRONTEND=noninteractive
RUN ln -fs /usr/share/zoneinfo/Asia/Seoul /etc/localtime && \
    apt update && apt install -y tzdata && \
    dpkg-reconfigure --frontend noninteractive tzdata

# Nvidia required packages
RUN apt install -y \
        libgles2 \
        libpangoft2-1.0-0 \
        libxkbcommon0 \
        libwayland-egl1 \
        libwayland-cursor0 \
        libunwind8 \
        libasound2 \
        libpixman-1-0 \
        libjpeg-turbo8 \
        libinput10 \
        libcairo2 \
        device-tree-compiler \
        iso-codes \
        libncursesw5 \
        libdrm-common \
        libdrm2 \
        libegl-mesa0 \
        libegl1 \
        libegl1-mesa \
        libgtk-3-0 \
        libgstreamer1.0-0 \
        libgstreamer-plugins-bad1.0-0 \
        i2c-tools \
        bridge-utils \
        libffi7 \
        libvulkan1 \
        libssl1.1 && \
        apt install -y wget cpio busybox && \
        wget http://launchpadlibrarian.net/354032550/libffi6_3.2.1-8_arm64.deb && \
        dpkg -i libffi6_3.2.1-8_arm64.deb


# Additional tools
RUN apt install -y \
        systemd \
        bash-completion \
        build-essential \
        pkg-config \
        btrfs-progs \
        cmake \
        curl \
        dnsutils \
        htop \
        iotop \
        isc-dhcp-client \
        iputils-ping \
        kmod \
        locales \
        net-tools \
        netplan.io \
        pciutils \
        python3-dev \
        ssh \
        sudo \
        udev \
        unzip \
        usbutils \
        neovim \
        wpasupplicant \
        parted \
        gdisk \
        fdisk \
        e2fsprogs \
        mtd-utils \
        python-is-python3 \
        git \
        network-manager \
        efibootmgr \
        nvme-cli \
        libseat1 \
        zstd

RUN wget -q https://github.com/pythops/tegratop/releases/latest/download/tegratop-linux-arm64 -O /usr/local/bin/tegratop && \
    chmod +x /usr/local/bin/tegratop

# ROS2 Humble
RUN apt install -y software-properties-common && \
    add-apt-repository universe && \
    apt update && \
    curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key -o /usr/share/keyrings/ros-archive-keyring.gpg && \
    echo "deb [arch=arm64 signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu jammy main" > /etc/apt/sources.list.d/ros2.list && \
    apt update && \
    apt install -y \
        ros-humble-ros-base \
        ros-humble-rmw-fastrtps-cpp \
        ros-humble-rosidl-typesupport-fastrtps-c \
        ros-humble-rosidl-typesupport-fastrtps-cpp \
        ros-humble-asio-cmake-module \
        ros-humble-serial-driver \
        ros-humble-io-context \
        ros-dev-tools \
        python3-argcomplete \
        python3-colcon-common-extensions \
        python3-rosdep && \
    rosdep init

# Source ROS2 in default shell for all users
RUN echo "source /opt/ros/humble/setup.bash" >> /etc/skel/.bashrc && \
    echo "source /opt/ros/humble/setup.zsh" >> /etc/skel/.zshrc

# Desktop environment (lightweight, needed for NoMachine/XRDP)
RUN apt install -y xfce4 dbus-x11 && \
    apt purge -y firefox* || true

# Chromium browser (ARM64 native, no official Chrome for ARM)
RUN apt install -y chromium-browser

# Terminator terminal emulator + set as default for XFCE/Thunar
RUN apt install -y terminator && \
    mkdir -p /etc/skel/.config/xfce4 && \
    echo "TerminalEmulator=terminator" > /etc/skel/.config/xfce4/helpers.rc && \
    update-alternatives --set x-terminal-emulator /usr/bin/terminator

# ibus-hangul (Korean input) + remap Alt_R to Hangul key
RUN apt install -y ibus ibus-hangul && \
    sed -i 's/^	<RALT> = 108;/	\/\/<RALT> = 108;/' /usr/share/X11/xkb/keycodes/evdev && \
    sed -i 's/^	<HNGL> = 130;/	<HNGL> = 108;/' /usr/share/X11/xkb/keycodes/evdev

# NoMachine remote desktop
RUN wget -q https://web9001.nomachine.com/download/9.4/Arm/nomachine_9.4.14_1_arm64.deb -O /tmp/nomachine.deb && \
    dpkg -i /tmp/nomachine.deb && \
    rm /tmp/nomachine.deb && \
    systemctl enable nxserver

# XRDP removed — NoMachine is the sole remote desktop

# Dummy display driver (XRDP/NoMachine fallback when no HDMI connected)
# xorg-dummy.conf lives at /etc/X11/ and is conditionally copied to
# xorg.conf.d/ by setup-xorg-display.service at boot (only if no HDMI)
RUN apt install -y xserver-xorg-video-dummy
COPY config/xorg-dummy.conf /etc/X11/xorg-dummy.conf
COPY scripts/setup-xorg-display.sh /usr/local/bin/setup-xorg-display.sh
COPY config/setup-xorg-display.service /lib/systemd/system/setup-xorg-display.service
RUN chmod +x /usr/local/bin/setup-xorg-display.sh && \
    systemctl enable setup-xorg-display.service

# Zsh + Oh My Zsh
RUN apt install -y zsh

# Antigravity (Google's VS Code with Gemini)
RUN mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://us-central1-apt.pkg.dev/doc/repo-signing-key.gpg | \
    gpg --dearmor --yes -o /etc/apt/keyrings/antigravity-repo-key.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/antigravity-repo-key.gpg] https://us-central1-apt.pkg.dev/projects/antigravity-auto-updater-dev/ antigravity-debian main" > /etc/apt/sources.list.d/antigravity.list && \
    apt update && \
    apt install -y antigravity

# Claude Code (installed per-user below)

# Resize the rootfs
COPY scripts/resizerootfs.sh /usr/local/bin
COPY scripts/resizerootfs.service /lib/systemd/system

# Maximize Jetson clocks at boot
COPY config/jetson-clocks.service /lib/systemd/system

# Generate locales
RUN locale-gen en_US.UTF-8

# Network configuration
COPY config/netcfg.yaml /etc/netplan/netcfg.yaml

# udev rules for F1TENTH sensors (Hokuyo LiDAR, VESC, Joypad)
COPY config/99-hokuyo.rules /etc/udev/rules.d/99-hokuyo.rules
COPY config/99-vesc.rules /etc/udev/rules.d/99-vesc.rules
COPY config/99-joypad-f710.rules /etc/udev/rules.d/99-joypad-f710.rules

# Enable services at startuo
RUN systemctl enable resizerootfs.service && \
    systemctl enable systemd-timesyncd && \
    systemctl enable jetson-clocks.service

# New user
# username: MIRU
# password: 2
RUN useradd \
        --create-home \
        -G sudo,video,audio,dialout \
        -p $(openssl passwd -6 2) \
        -s /usr/bin/zsh \
        MIRU

# F1TENTH driver stack workspace - clone only
# (build will run on first boot via systemd service, avoiding QEMU issues)
RUN mkdir -p /home/MIRU/f1tenth_ws/src && \
    cd /home/MIRU/f1tenth_ws/src && \
    git clone https://github.com/f1tenth/f1tenth_system.git && \
    cd f1tenth_system && \
    git submodule update --init --force && \
    chown -R MIRU:MIRU /home/MIRU/f1tenth_ws

# First-boot build script for F1TENTH workspace
COPY scripts/f1tenth-first-boot.sh /usr/local/bin/f1tenth-first-boot.sh
COPY config/f1tenth-first-boot.service /lib/systemd/system/f1tenth-first-boot.service
RUN chmod +x /usr/local/bin/f1tenth-first-boot.sh && \
    systemctl enable f1tenth-first-boot.service

# Add /usr/local/cuda/bin to the PATH
RUN echo "if [ -d \"/usr/local/cuda/bin\" ] ; then" >> /home/MIRU/.profile  && \
    echo "  PATH=\"/usr/local/cuda/bin:\$PATH\"" >> /home/MIRU/.profile  && \
    echo "fi" >> /home/MIRU/.profile

# Source ROS2 Humble and F1TENTH workspace for MIRU user
RUN echo 'export PATH="$HOME/.local/bin:$PATH"' >> /home/MIRU/.bashrc && \
    echo "source /opt/ros/humble/setup.bash" >> /home/MIRU/.bashrc && \
    echo "source ~/f1tenth_ws/install/setup.bash 2>/dev/null" >> /home/MIRU/.bashrc

# Install Claude Code as MIRU user
RUN su - MIRU -c 'curl -fsSL https://claude.ai/install.sh | bash'

# Install Oh My Zsh + plugins for MIRU user
RUN su - MIRU -c 'sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended' && \
    git clone https://github.com/zsh-users/zsh-syntax-highlighting.git /home/MIRU/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting && \
    git clone https://github.com/zsh-users/zsh-autosuggestions.git /home/MIRU/.oh-my-zsh/custom/plugins/zsh-autosuggestions && \
    sed -i 's/plugins=(git)/plugins=(git zsh-syntax-highlighting zsh-autosuggestions)/' /home/MIRU/.zshrc && \
    echo 'export PATH="$HOME/.local/bin:$PATH"' >> /home/MIRU/.zshrc && \
    echo "source /opt/ros/humble/setup.zsh" >> /home/MIRU/.zshrc && \
    echo "source ~/f1tenth_ws/install/setup.zsh 2>/dev/null" >> /home/MIRU/.zshrc && \
    chown -R MIRU:MIRU /home/MIRU/.oh-my-zsh /home/MIRU/.zshrc

# Set Terminator as default terminal for MIRU in XFCE
RUN mkdir -p /home/MIRU/.config/xfce4 && \
    echo "TerminalEmulator=terminator" > /home/MIRU/.config/xfce4/helpers.rc && \
    chown -R MIRU:MIRU /home/MIRU/.config

# Set XFCE as default desktop session for NoMachine
RUN echo "[Desktop]" > /home/MIRU/.dmrc && \
    echo "Session=xfce" >> /home/MIRU/.dmrc && \
    chown MIRU:MIRU /home/MIRU/.dmrc

# Clean apt cache (final cleanup)
RUN rm -rf /var/lib/apt/lists/*
